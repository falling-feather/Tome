# OpenTelemetry / Jaeger 本地调用链示例配置
# ----------------------------------------------------------------
# 用法：
#   1. 启动 Jaeger：
#      docker compose --profile otel up -d jaeger
#   2. 把此文件另存为 .env（或把下面几项合入现有 .env）
#   3. 启动后端：python -m uvicorn backend.app.main:app --reload
#   4. 触发一次游戏回合或 /api/admin/health 后
#      打开 http://localhost:16686 查看 service=inkless-backend 的 trace

OTEL_ENABLED=true
OTEL_SERVICE_NAME=inkless-backend
OTEL_SAMPLE_RATIO=1.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# 设为 true 时额外向 stdout 打印 span，便于无 Jaeger 的本地调试
OTEL_CONSOLE_EXPORT=false
